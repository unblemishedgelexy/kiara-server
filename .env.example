PORT=4000
NODE_ENV=production

# Add your deployed web frontend plus native app origins.
# Keep capacitor://localhost and ionic://localhost for Android/iOS WebView builds.
CLIENT_ORIGIN=https://your-frontend-domain.com,capacitor://localhost,ionic://localhost,http://localhost,http://localhost:5173,http://localhost:8100

MONGODB_URI=mongodb://127.0.0.1:27017/kiara_ai
JWT_SECRET=change-me-before-production
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
COOKIE_DOMAIN=

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Leda

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Email / SMTP configuration
EMAIL_FROM=your-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Redis Configuration for Short-Term Memory (STM)
# Use Redis Cloud (https://redis.com/try-free/) or local Redis
# If REDIS_URL is provided, it will be used first.
# For passwordless Redis leave REDIS_PASSWORD blank.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# Pinecone Configuration for Long-Term Memory (LTM)
# Create account at https://www.pinecone.io
# Create an index with dimension 1536 and cosine metric
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=kiara-long-term-memory
PINECONE_VECTOR_DIMENSION=1536

# Memory System Settings
MEMORY_RECENT_MESSAGE_LIMIT=10
MEMORY_SUMMARY_BATCH_SIZE=5
MEMORY_SUMMARY_TRIGGER=5
SHORT_TERM_MEMORY_TTL=3600
